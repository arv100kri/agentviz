{
  "name": "agentviz",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentviz": "./bin/agentviz.js",
    "fax-viz": "./bin/fax-viz.js"
  },
  "files": [
    "bin",
    "mcp",
    "dist",
    "dist-cli",
    "dist-fax-viz",
    "server.js",
    "fax-viz-server.js"
  ],
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:web:debug": "vite build --mode debug",
    "build:cli": "vite build --config vite.cli.config.js",
    "build:cli:debug": "vite build --config vite.cli.config.js --mode debug",
    "build:fax-viz": "vite build --config vite.fax-viz.config.js",
    "build:fax-viz:debug": "vite build --config vite.fax-viz.config.js --mode debug",
    "build": "npm run build:web && npm run build:cli",
    "build:debug": "npm run build:web:debug && npm run build:cli:debug",
    "dev:fax-viz": "vite --config vite.fax-viz.config.js",
    "preview": "vite preview",
    "app": "npm run build && node ./bin/agentviz.js",
    "app:debug": "npm run build:debug && node ./bin/agentviz.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "elkjs": "^0.11.1",
    "lucide-react": "^0.577.0",
    "lunr": "^2.3.9",
    "openai": "^6.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
