{
  "name": "fax-viz",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "bin": {
    "fax-viz": "./bin/fax-viz.js"
  },
  "files": [
    "bin",
    "dist-fax-viz",
    "src",
    "fax-viz-server.js"
  ],
  "scripts": {
    "dev": "vite --config vite.fax-viz.config.js",
    "build": "vite build --config vite.fax-viz.config.js",
    "build:debug": "vite build --config vite.fax-viz.config.js --mode debug",
    "build:bundle": "npm run build && node esbuild.fax-viz.mjs",
    "preview": "vite preview --config vite.fax-viz.config.js",
    "prepare": "npm run build",
    "test": "vitest run --config vite.fax-viz.config.js",
    "test:watch": "vitest --config vite.fax-viz.config.js",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "lucide-react": "^0.577.0",
    "lunr": "^2.3.9",
    "openai": "^6.32.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
